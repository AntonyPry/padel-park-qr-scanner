# database
DB_USER=
DB_PASSWORD=
DB_NAME=
HOST=127.0.0.1

# ordinary Account password hashing rollout; keep false until SEC-A4 abuse
# throttling and production-like CPU/memory/concurrency preflight are accepted
AUTH_ARGON2_ENABLED=false
# Argon2id PHC write parameters. The dual reader is always active, including
# when writes/rehash are disabled. Values are validated at server startup.
AUTH_ARGON2_MEMORY_KIB=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1

# staged multi-tenant rollout (server-owned; set every flag explicitly)
# full-stop blocks API/provider/worker/socket traffic except /api/health and
# /api/openapi.json. Disable it only during an authorized smoke window.
SETLY_ROLLOUT_MAINTENANCE_MODE=off
# Temporary production-day exception; true is valid only with full-stop and
# only while switching the canonical Beeline capability callback.
SETLY_BEELINE_CAPABILITY_CUTOVER_ENABLED=false
TENANT_CONTEXT_ENABLED=false
TENANT_CACHE_REALTIME_ENABLED=false
TENANT_FILES_WORKERS_ENABLED=false
TENANT_PROVIDER_INTEGRATIONS_ENABLED=false
TENANT_STAFF_ACCESS_ENABLED=false
TENANT_CLIENTS_REFERENCES_ENABLED=false
TENANT_VISITS_SCANNER_ENABLED=false
TENANT_CLIENT_BASES_CALL_TASKS_ENABLED=false
TENANT_BOOKINGS_COURTS_ENABLED=false
TENANT_METHODOLOGY_SKILL_MAP_ENABLED=false
TENANT_TRAINING_NOTES_PLANS_ENABLED=false
TENANT_CLIENT_MONEY_INSTRUMENTS_ENABLED=false
TENANT_SHIFTS_REPORTS_ENABLED=false
TENANT_AUDIT_LOG_ENABLED=false
TENANT_ONBOARDING_ENABLED=false
TENANT_ENFORCEMENT_ENABLED=false

# keep external mutation sources disabled for maintenance/rehearsal windows
BOTS_ENABLED=false
BACKGROUND_RUNNERS_ENABLED=false

# persistent installation key for provider credential encryption; generate once,
# keep outside git/logs/manifests, and preserve across deploy/restart/restore
INTEGRATION_SECRETS_MASTER_KEY=
INTEGRATION_SECRETS_KEY_VERSION=v1

# installation-level operator (secrets belong only in protected server env)
INSTALLATION_PROVISIONING_ENABLED=false
INSTALLATION_MANAGEMENT_ENABLED=false
INSTALLATION_OPERATOR_USERNAME=
# generate offline with: npm run --silent auth:installation-operator-hash
INSTALLATION_OPERATOR_PASSWORD_HASH=
INSTALLATION_OPERATOR_SECRET=
PUBLIC_APP_URL=https://setly.tech
INSTALLATION_ACTIVATION_BASE_URL=https://setly.tech
# public backend origin used only to display exact Evotor connection callbacks
INSTALLATION_PROVIDER_CALLBACK_BASE_URL=https://api.setly.tech

# bot
BOT_TOKEN=
VK_TOKEN=v

# beeline telephony
BEELINE_API_TOKEN=
BEELINE_API_BASE_URL=https://cloudpbx.beeline.ru/apis/portal
BEELINE_CALLBACK_URL=
# Optional explicit shared-header mode. When blank, bootstrap creates the
# canonical encrypted callback-capability mode; it never generates this value.
BEELINE_WEBHOOK_SECRET=
BEELINE_WEBHOOK_REQUIRE_SECRET=true
BEELINE_STATISTICS_PATH=/v2/statistics
BEELINE_RECORDS_PATH=/records
BEELINE_SUBSCRIPTION_PATH=/subscription
BEELINE_SUBSCRIPTION_TYPE=BASIC_CALL
BEELINE_SUBSCRIPTION_EXPIRES=3600
BEELINE_SUBSCRIPTION_PATTERN=
BEELINE_SUBSCRIPTION_AUTORENEW_ENABLED=true
BEELINE_SUBSCRIPTION_RENEW_BEFORE_SECONDS=600
BEELINE_SUBSCRIPTION_RUNNER_INTERVAL_MS=300000
